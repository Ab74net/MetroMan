generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Line {
  id             String          @id @db.Text
  name           String          @db.Text
  colorHex       String          @map("color_hex") @db.Text
  displayOrder   Int             @map("display_order")
  stationLines   StationLine[]
  routeSegments  RouteSegment[]
  trips          Trip[]
  trainPositions TrainPosition[]
  predictions    Prediction[]

  @@map("lines")
}

model Station {
  id                     String          @id @db.Text
  name                   String          @db.Text
  location               Unsupported("geography(POINT, 4326)")
  address                String?         @db.Text
  isTransferStation      Boolean         @map("is_transfer_station")
  hasElevator            Boolean         @map("has_elevator")
  hasParking             Boolean         @map("has_parking")
  createdAt              DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  stationLines           StationLine[]
  routeSegmentsFrom      RouteSegment[]  @relation("RouteSegmentFrom")
  routeSegmentsTo        RouteSegment[]  @relation("RouteSegmentTo")
  currentTrainPositions  TrainPosition[] @relation("PositionCurrent")
  nextTrainPositions     TrainPosition[] @relation("PositionNext")
  stationPredictions     Prediction[]    @relation("PredictionsAtStation")
  destinationPredictions Prediction[]    @relation("PredictionsDestination")

  @@map("stations")
}

model StationLine {
  stationId String  @map("station_id") @db.Text
  lineId    String  @map("line_id") @db.Text
  sequence  Int
  station   Station @relation(fields: [stationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  line      Line    @relation(fields: [lineId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([stationId, lineId])
  @@index([lineId, sequence])
  @@map("station_lines")
}

model RouteSegment {
  id            Int     @id @default(autoincrement())
  lineId        String  @map("line_id") @db.Text
  fromStationId String  @map("from_station_id") @db.Text
  toStationId   String  @map("to_station_id") @db.Text
  sequence      Int
  geometry      Unsupported("geography(LINESTRING, 4326)")
  lengthMeters  Float   @default(dbgenerated("st_length(geometry)")) @map("length_meters") @db.DoublePrecision
  line          Line    @relation(fields: [lineId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  fromStation   Station @relation("RouteSegmentFrom", fields: [fromStationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  toStation     Station @relation("RouteSegmentTo", fields: [toStationId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([lineId, sequence])
  @@map("route_segments")
}

model Trip {
  id        String          @id @db.Text
  lineId    String          @map("line_id") @db.Text
  headsign  String          @db.Text
  direction Int
  shapeId   String          @map("shape_id") @db.Text
  line      Line            @relation(fields: [lineId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  positions TrainPosition[]

  @@index([lineId, direction])
  @@map("trips")
}

model TrainPosition {
  trainId          String       @id @map("train_id") @db.Text
  tripId           String       @map("trip_id") @db.Text
  lineId           String       @map("line_id") @db.Text
  position         Unsupported("geography(POINT, 4326)")
  bearing          Float        @db.DoublePrecision
  speedKmh         Float        @map("speed_kmh") @db.DoublePrecision
  currentStationId String?      @map("current_station_id") @db.Text
  nextStationId    String?      @map("next_station_id") @db.Text
  progressPct      Float        @map("progress_pct") @db.DoublePrecision
  updatedAt        DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)
  trip             Trip         @relation(fields: [tripId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  line             Line         @relation(fields: [lineId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  currentStation   Station?     @relation("PositionCurrent", fields: [currentStationId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  nextStation      Station?     @relation("PositionNext", fields: [nextStationId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  predictions      Prediction[]

  @@index([lineId, updatedAt])
  @@index([tripId])
  @@map("train_positions")
}

model Prediction {
  id            Int           @id @default(autoincrement())
  stationId     String        @map("station_id") @db.Text
  trainId       String        @map("train_id") @db.Text
  lineId        String        @map("line_id") @db.Text
  destinationId String        @map("destination_id") @db.Text
  minutesAway   Int           @map("minutes_away")
  carCount      Int           @map("car_count")
  capturedAt    DateTime      @default(now()) @map("captured_at") @db.Timestamptz(6)
  station       Station       @relation("PredictionsAtStation", fields: [stationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  train         TrainPosition @relation(fields: [trainId], references: [trainId], onDelete: Cascade, onUpdate: Cascade)
  line          Line          @relation(fields: [lineId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  destination   Station       @relation("PredictionsDestination", fields: [destinationId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([stationId, capturedAt])
  @@map("predictions")
}

model Alert {
  id                 String   @id @db.Text
  header             String   @db.Text
  description        String   @db.Text
  severity           String   @db.Text
  affectedLineIds    String[] @map("affected_line_ids")
  affectedStationIds String[] @map("affected_station_ids")
  startsAt           DateTime @map("starts_at") @db.Timestamptz(6)
  endsAt             DateTime? @map("ends_at") @db.Timestamptz(6)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("alerts")
}
